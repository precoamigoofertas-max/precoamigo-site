---
---
<footer>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <div class="footer-container">
        <nav class="footer-section">
            <h4>Institucional</h4>
            <div class="links-vertical">
                <a href="/politica-privacidade">Política de Privacidade</a>
                <a href="/termos-uso">Termos de Uso</a>
                <a href="/contato">Contato</a>
            </div>
        </nav>

        <section class="footer-section">
            <h4>Siga-nos</h4>
            <div class="social-links">
                <a href="URL_TIKTOK"><i class="fa-brands fa-tiktok"></i> TikTok</a>
                <a href="URL_YOUTUBE"><i class="fa-brands fa-youtube"></i> YouTube</a>
                <a href="URL_INSTA"><i class="fa-brands fa-instagram"></i> Instagram</a>
                <a href="URL_FB"><i class="fa-brands fa-facebook"></i> Facebook</a>
            </div>
        </section>
    </div>

    <div class="footer-bottom">
        <p class="disclosure">
            O Preco Amigo participa do Programa de Associados da Amazon e outros afiliados. 
            Ao clicar em nossos links, podemos ganhar uma comissão, sem custo adicional para você.
        </p>
        <p class="copyright">&copy; {new Date().getFullYear()} Preco Amigo. Todos os direitos reservados.</p>
    </div>
</footer>

<style>
    footer { background: #131921; color: #fff; padding: 3rem 1rem; border-top: 4px solid #FF9900; }
    
    .footer-container { 
        display: flex; 
        justify-content: center; 
        gap: 8rem; /* Aumentado para separar bem as colunas */
        margin-bottom: 2rem;
        flex-wrap: wrap; 
    }

    h4 { color: #FF9900; font-size: 0.95rem; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.05em; }
    
    .links-vertical a, .social-links a { 
        display: block; color: #ccc; text-decoration: none; font-size: 0.9rem; margin-bottom: 12px;
    }
    .links-vertical a:hover, .social-links a:hover { color: #fff; }
    
    .social-links a i { width: 20px; margin-right: 8px; } /* Alinhamento dos ícones */

    .footer-bottom { text-align: center; border-top: 1px solid #232f3e; padding-top: 1.5rem; }
    .disclosure { font-size: 0.75rem; color: #888; max-width: 600px; margin: 0 auto 1rem auto; line-height: 1.5; }
    .copyright { font-size: 0.75rem; color: #666; }

    @media (max-width: 600px) {
        .footer-container { gap: 3rem; text-align: center; }
    }
</style>