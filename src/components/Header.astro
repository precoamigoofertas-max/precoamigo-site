---
// src/components/Header.astro
---

<header class="main-header">
  <nav class="nav-container" aria-label="Navegação Principal do Preco Amigo">
    
    <a href="/" class="logo" aria-label="Ir para a página inicial do Preco Amigo">
      <img src="/logo.png" alt="Logotipo Preco Amigo" class="logo-img" width="220" height="80" decoding="async" />
    </a>
    
    <button id="menu-toggle" class="mobile-menu-btn" aria-label="Abrir menu de navegação" aria-expanded="false" aria-controls="main-nav-links">
      <svg class="hamburger-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 12L20 12M4 6L20 6M4 18L20 18"></path>
      </svg>
    </button>
    
    <ul id="main-nav-links" class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/categorias/tecnologia">Tecnologia</a></li>
      <li><a href="/categorias/casa">Casa</a></li>
      <li><a href="/categorias/achadinhos">Achadinhos</a></li>
      <li><a href="/categorias/automotivo">Automotivo</a></li>
      <li><a href="/categorias/ofertas-do-dia">Ofertas do Dia</a></li>
    </ul>
  </nav>
</header>

<div class="affiliate-disclosure">
    <div class="disclosure-container">
        <p>O Preco Amigo participa do Programa de Associados da Amazon e outros afiliados. Comprando pelos nossos links, podemos ganhar uma comissão, sem custo adicional para você.</p>
    </div>
</div>

<style>
  /* --- Estilos Gerais e Desktop --- */
  .main-header {
    background-color: #131921;
    width: 100%;
    position: relative;
    z-index: 100;
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.2rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    z-index: 101;
  }

  .logo-img {
    max-height: 80px;
    width: auto;
    display: block;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    color: #ffffff;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: #FF9900;
  }

  .affiliate-disclosure {
    background-color: #ffffff;
    border-bottom: 1px solid #eaeaea;
    width: 100%;
  }

  .disclosure-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 6px 1.5rem;
    text-align: right;
  }
  
  .disclosure-container p {
    margin: 0;
    color: #000000;
    font-size: 0.75rem;
    font-weight: 400;
    line-height: 1.4;
  }

  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    z-index: 101;
    align-items: center;
    justify-content: center;
  }

  /* --- ESTILOS MOBILE E MENU HAMBÚRGUER --- */
  @media (max-width: 768px) {
    .nav-container { padding: 0.8rem 1rem; }
    .logo-img { max-height: 50px; }
    .mobile-menu-btn { display: flex; }

    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      background-color: #131921;
      flex-direction: column;
      gap: 0;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease-out;
      border-bottom: 2px solid #FF9900;
    }

    /* Aumentei levemente o max-height para 450px para garantir que todos os links caibam no mobile */
    .nav-links.active { max-height: 450px; }

    .nav-links li { text-align: center; border-top: 1px solid rgba(255, 255, 255, 0.05); }
    .nav-links a { display: block; padding: 1.2rem; font-size: 1.1rem; }
    .disclosure-container { text-align: center; padding: 8px 1rem; }
  }
</style>

<script>
  const btn = document.getElementById('menu-toggle');
  const nav = document.getElementById('main-nav-links');

  if (btn && nav) {
    btn.addEventListener('click', () => {
      nav.classList.toggle('active');
      const isOpen = nav.classList.contains('active');
      btn.setAttribute('aria-expanded', isOpen.toString());
    });
  }
</script>