---
<header>
    <nav class="nav-container">
        <div class="logo">
            <a href="/"><img src="/logo.png" alt="Logo Preco Amigo" /></a>
        </div>
        
        <button class="hamburger" aria-label="Menu">
            <span></span><span></span><span></span>
        </button>

        <ul class="nav-links">
            <li><a href="/categorias/casa">Casa</a></li>
            <li><a href="/categorias/tecnologia">Tecnologia</a></li>
            <li><a href="/categorias/achadinhos">Achadinhos</a></li>
            <li><a href="/categorias/ofertas-do-dia">Ofertas do Dia</a></li>
        </ul>
    </nav>
</header>

<style>
    header { background: #131921; padding: 1rem; border-bottom: 4px solid #FF9900; }
    .nav-container { display: flex; align-items: center; justify-content: space-between; max-width: 1200px; margin: 0 auto; }
    
    .logo img { max-height: 40px; }

    /* Remove marcadores de lista e centraliza */
    .nav-links { display: flex; list-style: none; margin: 0; padding: 0; gap: 1.5rem; }
    .nav-links a { color: #fff; text-decoration: none; font-weight: 600; font-size: 1rem; }
    .nav-links a:hover { color: #FF9900; }

    .hamburger { display: none; background: none; border: none; cursor: pointer; }
    .hamburger span { display: block; width: 25px; height: 3px; background: #fff; margin: 5px 0; }

    /* Mobile */
    @media (max-width: 768px) {
        .hamburger { display: block; }
        .nav-links { 
            display: none; flex-direction: column; position: absolute; top: 70px; left: 0; width: 100%; 
            background: #131921; text-align: center; padding: 1rem 0; z-index: 10;
        }
        .nav-links.open { display: flex; }
        .nav-links li { padding: 10px 0; }
    }
</style>

<script>
    const hamburger = document.querySelector('.hamburger');
    const links = document.querySelector('.nav-links');
    hamburger?.addEventListener('click', () => links?.classList.toggle('open'));
</script>

<header>
    <nav class="nav-container">
        </nav>
    
    <div class="affiliate-disclosure">
        <p>
            O Preco Amigo participa do Programa de Associados da Amazon e outros afiliados. Ao clicar em nossos links, podemos ganhar uma comissão, sem custo adicional para você.
        </p>
    </div>
</header>

<style>
    /* ... (seus estilos existentes) ... */

  .affiliate-disclosure {
        background: #131921; /* Mantém a mesma cor de fundo do cabeçalho */
        color: #FF9900; /* Letras no tom laranja da marca */
        font-size: 0.7rem; 
        text-align: center;
        padding: 8px 1rem;
        border-top: 1px solid rgba(255, 255, 255, 0.05); /* Linha divisória quase invisível só para dar estrutura */
    }
    
    .affiliate-disclosure p {
        margin: 0;
        font-style: italic;
        letter-spacing: 0.3px; /* Dá um pouco mais de espaço entre as letras para facilitar a leitura */
        opacity: 0.8; /* Suaviza o laranja para ficar mais sofisticado e menos agressivo à vista */
    }
</style>