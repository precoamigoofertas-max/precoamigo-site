---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="pt-BR">
    <head>
        <BaseHead 
            title="Contato | Preco Amigo" 
            description="Fale com a equipe do Preco Amigo. Dúvidas, parcerias ou sugestões de análises? Envie uma mensagem para nós." 
        />
    </head>
    <body>
        <Header />

        <main class="legal-container">
            <div class="legal-content contact-wrapper">
                
                <div class="contact-info">
                    <h1>Entre em Contato</h1>
                    <p>Tem alguma dúvida sobre uma análise, sugestão de produto para testarmos ou interesse em parcerias? Fale com a nossa equipe!</p>
                    
                    <div class="direct-email">
                        <h3>Nosso E-mail Direto</h3>
                        <p>Prefere o método tradicional? Envie um e-mail para:</p>
                        <a href="mailto:precoamigo@gmail.com" class="email-link">precoamigo@gmail.com</a>
                    </div>
                    
                    <div class="response-time">
                        <p>⏱️ <em>Geralmente respondemos em até 24 horas úteis.</em></p>
                    </div>
                </div>

                <div class="contact-form-container">
                    <form action="https://formsubmit.co/precoamigo@gmail.com" method="POST" class="contact-form">
                        
                        <input type="hidden" name="_subject" value="Novo contato pelo site Preco Amigo!">
                        <input type="hidden" name="_captcha" value="false"> <input type="hidden" name="_template" value="table">
                        
                        <div class="form-group">
                            <label for="name">Seu Nome</label>
                            <input type="text" id="name" name="name" required placeholder="Como podemos te chamar?">
                        </div>

                        <div class="form-group">
                            <label for="email">Seu E-mail</label>
                            <input type="email" id="email" name="email" required placeholder="seu@email.com">
                        </div>

                        <div class="form-group">
                            <label for="message">Mensagem</label>
                            <textarea id="message" name="message" rows="5" required placeholder="Escreva sua dúvida ou sugestão aqui..."></textarea>
                        </div>

                        <button type="submit" class="submit-btn">Enviar Mensagem</button>
                    </form>
                </div>

            </div>
        </main>

        <Footer />
    </body>
</html>

<style>
    /* Reaproveitando a estrutura base das páginas legais */
    .legal-container {
        max-width: 900px; 
        margin: 3rem auto;
        padding: 0 1.5rem;
    }

    .legal-content {
        background: #ffffff;
        border-radius: 8px;
        border: 1px solid #eaeaea;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.02);
        overflow: hidden; /* Para conter as colunas */
    }

    /* Layout em duas colunas para o Contato */
    .contact-wrapper {
        display: flex;
        flex-wrap: wrap;
    }

    .contact-info {
        flex: 1;
        min-width: 300px;
        padding: 2.5rem;
        background-color: #f9f9fa;
        border-right: 1px solid #eaeaea;
    }

    .contact-info h1 {
        color: #131921;
        font-size: 2.2rem;
        margin-top: 0;
        margin-bottom: 1rem;
    }

    .contact-info p {
        color: #555;
        line-height: 1.6;
        margin-bottom: 2rem;
    }

    .direct-email h3 {
        color: #131921;
        font-size: 1.2rem;
        margin-bottom: 0.5rem;
    }

    .email-link {
        display: inline-block;
        font-size: 1.1rem;
        font-weight: 700;
        color: #FF9900;
        text-decoration: none;
        padding: 8px 0;
        transition: color 0.2s;
    }

    .email-link:hover {
        color: #131921;
    }

    .response-time {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid #eaeaea;
    }

    .response-time p {
        font-size: 0.9rem;
        color: #666;
        margin: 0;
    }

    /* Estilos do Formulário */
    .contact-form-container {
        flex: 1.2;
        min-width: 320px;
        padding: 2.5rem;
    }

    .contact-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-group label {
        font-weight: 600;
        color: #131921;
        font-size: 0.95rem;
    }

    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 12px;
        border: 1px solid #ccc;
        border-radius: 6px;
        font-family: inherit;
        font-size: 1rem;
        transition: border-color 0.2s;
        box-sizing: border-box;
    }

    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: #FF9900;
        box-shadow: 0 0 0 2px rgba(255, 153, 0, 0.1);
    }

    .submit-btn {
        background-color: #131921;
        color: #fff;
        border: none;
        padding: 14px;
        border-radius: 6px;
        font-size: 1.05rem;
        font-weight: 700;
        cursor: pointer;
        transition: background-color 0.2s;
        margin-top: 0.5rem;
    }

    .submit-btn:hover {
        background-color: #FF9900;
        color: #111;
    }

    /* Responsividade */
    @media (max-width: 768px) {
        .contact-wrapper {
            flex-direction: column;
        }
        .contact-info {
            border-right: none;
            border-bottom: 1px solid #eaeaea;
            padding: 2rem 1.5rem;
        }
        .contact-form-container {
            padding: 2rem 1.5rem;
        }
    }
</style>