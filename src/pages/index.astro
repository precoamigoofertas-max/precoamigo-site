---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="pt-br">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Bem-vindos ao Preco Amigo! 🚀</h1>
			<p>
				Aqui você vai encontrar as melhores ofertas de tecnologia, itens indispensáveis para a sua casa e os melhores achadinhos testados e aprovados.
			</p>
		</main>
		<Footer />
	</body>
</html>