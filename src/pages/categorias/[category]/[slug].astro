---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';
import JsonLd from '../../../components/JsonLd.astro';
import { SITE_URL } from '../../../consts';
import { getPostUrl } from '../../../utils/content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts
		.filter((post) => !post.data.draft && post.data.category)
		.map((post) => ({
			params: { category: post.data.category, slug: post.id },
			props: { post },
		}));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await render(post);
const articleUrl = new URL(getPostUrl(post), SITE_URL).href;
---

<BlogPost
	title={post.data.title}
	description={post.data.description}
	pubDate={post.data.pubDate}
	updatedDate={post.data.updatedDate}
	heroImage={post.data.heroImage}
	ogType="article"
>
	<Fragment slot="head">
		<JsonLd
			schema={{
				'@context': 'https://schema.org',
				'@type': 'BreadcrumbList',
				itemListElement: [
					{ '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
					{
						'@type': 'ListItem',
						position: 2,
						name: post.data.category,
						item: new URL(`/categorias/${post.data.category}/`, SITE_URL).href,
					},
					{ '@type': 'ListItem', position: 3, name: post.data.title, item: articleUrl },
				],
			}}
		/>
		<JsonLd
			schema={{
				'@context': 'https://schema.org',
				'@type': 'Article',
				headline: post.data.title,
				description: post.data.description,
				datePublished: post.data.pubDate.toISOString(),
				dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
				mainEntityOfPage: articleUrl,
				author: { '@type': 'Organization', name: 'Equipe Preco Amigo' },
				publisher: {
					'@type': 'Organization',
					name: 'Preco Amigo',
					url: SITE_URL,
				},
			}}
		/>
	</Fragment>
	<Content />
</BlogPost>
