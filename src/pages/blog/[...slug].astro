---
import { getCollection } from 'astro:content';

/** Redireciona URLs antigas /blog/slug para /categorias/categoria/slug */
export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts
		.filter((post) => !post.data.draft && post.data.category)
		.map((post) => ({
			params: { slug: post.id },
			redirect: `/categorias/${post.data.category}/${post.id}/`,
		}));
}
